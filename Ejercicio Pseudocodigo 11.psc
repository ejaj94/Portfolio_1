Algoritmo sin_titulo
	
	Definir i, num, conteo Como Entero
	i = 0
	num = 0
	conteo = 0
	
	Escribir "Introduce un numero para obtener un conteo"
	Leer num
	
	Escribir "Comienza el conteo"
	Mientras (conteo <> num) Hacer
		escribir conteo 
		esperar 1 segundo
		conteo = conteo + 1
	FinMientras
	Escribir "El conteo ha terminado"
	
	
FinAlgoritmo
