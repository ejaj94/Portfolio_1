Algoritmo sin_titulo
	definir letra como texto
	
	letra = ""
	
	escribir "Escriba una letra para ver si es vocal o consonante"
	Leer letra
	
	si letra = "a" o letra  = "e" o letra = "i" o letra = "o" o letra = "u" Entonces
		Escribir "Esta letra es una vocal"
	SiNo
		Escribir "Esta letra no es una vocal, es una consonante"
		
		
	FinSi
	
FinAlgoritmo
